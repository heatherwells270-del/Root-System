function gid() { return Date.now().toString(36)+Math.random().toString(36).slice(2,6); }
function fmt(d) { return new Date(d).toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"}); }
function clampTrust(s) { return Math.max(TRUST.FLOOR,Math.min(TRUST.CEILING,s)); }
function countInWindow(ts,w) { const c=Date.now()-w; return ts.filter(t=>t>c).length; }
function pruneOld(ts,w) { const c=Date.now()-w; return ts.filter(t=>t>c); }
function daysUntilExpiry(created) { const e=new Date(created); e.setDate(e.getDate()+RATE.EXPIRY_DAYS); return Math.ceil((e-new Date())/86400000); }
function isExpired(p) { if(p.id?.startsWith("s")||p.expires==="2099-12-31") return false; return daysUntilExpiry(p.created)<=0; }
function expiryLabel(p) { if(p.id?.startsWith("s")||p.expires==="2099-12-31") return null; const d=daysUntilExpiry(p.created); if(d<=0) return S.expiration.expired; if(d<=1) return S.expiration.today; return S.expiration.daysLeft(d); }
function haversine(lat1,lon1,lat2,lon2) { const R=3959,dLat=(lat2-lat1)*Math.PI/180,dLon=(lon2-lon1)*Math.PI/180; const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2; return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a)); }
function distLabel(mi) { if(mi==null||isNaN(mi)) return null; if(mi<1) return "~<1 mi"; if(mi<50) return `~${Math.round(mi)} mi`; return "~50+ mi"; }
function appealDaysLeft(a) { const exp=new Date(a.created); exp.setDate(exp.getDate()+RATE.APPEAL_EXPIRY_DAYS); return Math.ceil((exp-new Date())/86400000); }

async function lookupZip(zip) {
  try { const c=new AbortController(); const t=setTimeout(()=>c.abort(),3000); const r=await fetch(`https://api.zippopotam.us/us/${zip}`,{signal:c.signal}); clearTimeout(t); if(r.ok){const d=await r.json(); if(d.places?.length) return {lat:+d.places[0].latitude,lon:+d.places[0].longitude,city:d.places[0]["place name"],state:d.places[0]["state abbreviation"]};} } catch{}
  const e=ZIP_PREFIX_CENTROIDS[zip.slice(0,3)]; return e?{lat:e.lat,lon:e.lon,city:null,state:null}:null;
}

