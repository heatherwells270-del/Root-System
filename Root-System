];
function detectScamWarnings(post) {
  const text = (post.title + " " + post.body).toLowerCase();
  return SCAM_PATTERNS.filter(p => p.regex.test(post.title + " " + post.body)).map(p => ({ id:p.id, msg:p.msg }));
}

