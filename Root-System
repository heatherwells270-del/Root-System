async function pGet(k){try{const r=await window.storage.get(k,false);return r?.value?JSON.parse(r.value):null}catch{return null}}
async function pSet(k,v){try{await window.storage.set(k,JSON.stringify(v),false)}catch(e){console.error("pSet:",k,e)}}
async function sGet(k){try{const r=await window.storage.get(k,true);return r?.value?JSON.parse(r.value):null}catch{return null}}
async function sSet(k,v){try{await window.storage.set(k,JSON.stringify(v),true)}catch(e){console.error("sSet:",k,e)}}
async function sDel(k){try{await window.storage.delete(k,true)}catch(e){console.error("sDel:",k,e)}}
async function sList(p){try{const r=await window.storage.list(p,true);return r?.keys||[]}catch{return[]}}
async function getOrCreateDeviceId(){let d=await pGet("device-id");if(d?.id)return d;const n={id:crypto.randomUUID(),created:Date.now()};await pSet("device-id",n);return n}
async function getTrustData(){const d=await pGet("trust-data");return d||{score:TRUST.STARTING,history:[]}}
async function adjustTrust(delta,event){const td=await getTrustData();td.score=clampTrust(td.score+delta);td.history.push({event,delta,timestamp:Date.now()});await pSet("trust-data",td);return td.score}

