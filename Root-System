// ═══════════════════════════════════════════════════════════════════════════════
// MAIN COMPONENT
// ═══════════════════════════════════════════════════════════════════════════════
export default function RootSystem() {
  const [loaded,setLoaded]=useState(false);const [deviceId,setDeviceId]=useState(null);const [covenantAccepted,setCovenantAccepted]=useState(false);const [trustData,setTrustData_]=useState({score:TRUST.STARTING,history:[]});
  const [view,setView]=useState("browse");const [msg,setMsg]=useState("");const [msgType,setMsgType]=useState("success");
  const [posts,setPosts]=useState([]);const [coalitions,setCoalitions]=useState([]);const [tbLog,setTbLog]=useState([]);
  const [appeals,setAppeals]=useState([]);const [blockedHandles,setBlockedHandles]=useState([]);
  const [postLog,setPostLog]=useState([]);const [flagLog,setFlagLog]=useState([]);const [voteLog,setVoteLog]=useState([]);
  const [catFilter,setCatFilter]=useState("all");const [typeFilter,setTypeFilter]=useState("all");const [zoneFilter,setZoneFilter]=useState("all");const [radiusFilter,setRadiusFilter]=useState("any");const [search,setSearch]=useState("");
  const [userZip,setUserZip]=useState(null);const [zipInput,setZipInput]=useState("");const [zipLooking,setZipLooking]=useState(false);
  const [form,setForm]=useState({type:"offer",freeSubtype:"items",category:"skills",title:"",body:"",contactInfo:"",zone:"Any / Network-wide",timebank:"",handle:"",tags:""});
  const [tbForm,setTbForm]=useState({from:"",to:"",hours:"",description:""});
  const [cForm,setCForm]=useState({title:"",purpose:"",members:"",contact:"",zone:"Any / Network-wide"});
  const [reportedIds,setReportedIds]=useState(new Set());const [myVotedAppeals,setMyVotedAppeals]=useState(new Set());
  const [contactModal,setContactModal]=useState(null);const [trustModal,setTrustModal]=useState(false);
  const [showBlocked,setShowBlocked]=useState(false);const [dismissedWarnings,setDismissedWarnings]=useState(new Set());
  const [appealText,setAppealText]=useState("");const mainRef=useRef(null);

  function flash(m,type="success"){setMsg(m);setMsgType(type);setTimeout(()=>setMsg(""),4000)}

  // ═══ INIT ═══
  useEffect(()=>{(async()=>{
    const dev=await getOrCreateDeviceId();setDeviceId(dev);
    const cov=await pGet("covenant-accepted");if(cov?.accepted)setCovenantAccepted(true);
    const td=await getTrustData();setTrustData_(td);
    const bh=await pGet("blocked-handles");if(bh?.handles)setBlockedHandles(bh.handles);
    const pl=await pGet("post-log");if(pl?.posts)setPostLog(pl.posts);
    const fl=await pGet("flag-log");if(fl?.flags)setFlagLog(fl.flags);
    const vl=await pGet("vote-log");if(vl?.votes)setVoteLog(vl.votes);
    const mv=await pGet("my-voted-appeals");if(mv?.ids)setMyVotedAppeals(new Set(mv.ids));
    const uz=await pGet("user-zip");if(uz?.zip)setUserZip(uz);

    const postKeys=await sList("posts:");const lp=[];
    for(const k of postKeys){const p=await sGet(k);if(p&&p.status==="active")lp.push(p)}
    const sid=new Set(lp.map(p=>p.id));const ap=[...lp];
    for(const s of SEED_POSTS){if(!sid.has(s.id)){ap.push(s);await sSet(`posts:${s.id}`,s)}}
    setPosts(ap);

    const coalKeys=await sList("coalitions:");const lc=[];
    for(const k of coalKeys){const c=await sGet(k);if(c)lc.push(c)}
    const cid=new Set(lc.map(c=>c.id));const ac=[...lc];
    for(const s of SEED_COALITIONS){if(!cid.has(s.id)){ac.push(s);await sSet(`coalitions:${s.id}`,s)}}
    setCoalitions(ac);

    // Load appeals
    const appealKeys=await sList("flagged-posts:");const la=[];
    for(const k of appealKeys){const a=await sGet(k);if(a&&a.status==="pending")la.push(a)}
    // Graceful decay: auto-restore if 3+ days, any restore votes, zero upholds
    for(const a of la){
      const days=(Date.now()-new Date(a.created).getTime())/86400000;
      if(days>=RATE.GRACEFUL_DECAY_DAYS&&(a.restoreVotes||0)>0&&(a.upholdVotes||0)===0){
        a.status="restored";await sSet(`flagged-posts:${a.id}`,a);
        // Re-activate original post
        const orig=await sGet(`posts:${a.postId}`);if(orig){orig.status="active";orig.flags=0;orig.flaggedBy=[];await sSet(`posts:${a.postId}`,orig);ap.push(orig);setPosts(prev=>[...prev,orig])}
      }
    }
    setAppeals(la.filter(a=>a.status==="pending"));

    const tbData=await sGet("timebank-ledger");if(tbData?.entries)setTbLog(tbData.entries);
    const sh=await pGet("user-handle");if(sh?.handle)setForm(f=>({...f,handle:sh.handle}));
    setLoaded(true);
  })()},[]);

  // ═══ ZIP ═══
  async function handleZipSubmit(e){e?.preventDefault();const z=zipInput.trim();if(!/^\d{5}$/.test(z)){flash(S.zip.notFound,"warning");return}
    setZipLooking(true);const r=await lookupZip(z);setZipLooking(false);if(!r){flash(S.zip.notFound,"warning");return}
    const d={zip:z,lat:r.lat,lon:r.lon,city:r.city,state:r.state,timestamp:Date.now()};setUserZip(d);await pSet("user-zip",d);setZipInput("")}
  function getPostDist(p){if(!userZip?.lat||!p.zip)return null;const c=ZIP_PREFIX_CENTROIDS[p.zip.slice(0,3)];return c?haversine(userZip.lat,userZip.lon,c.lat,c.lon):null}

  // ═══ COVENANT ═══
  async function acceptCovenant(){await pSet("covenant-accepted",{accepted:true,timestamp:Date.now(),version:"2026-02"});setCovenantAccepted(true)}

  // ═══ RATE LIMITS ═══
  function canPost(){const r24=countInWindow(postLog,RATE.MS_24H),r10=countInWindow(postLog,RATE.MS_10M);if(r24>=RATE.POST_MAX_24H)return{ok:false,reason:"daily"};if(r10>=RATE.POST_MAX_10M)return{ok:false,reason:"burst"};return{ok:true,remaining:RATE.POST_MAX_24H-r24}}
  function canFlag(){return countInWindow(flagLog,RATE.MS_24H)<RATE.FLAG_MAX_24H}
  function canVote(){return countInWindow(voteLog,RATE.MS_24H)<RATE.VOTE_MAX_24H}
  async function logPost(){const u=pruneOld([...postLog,Date.now()],RATE.MS_24H);setPostLog(u);await pSet("post-log",{posts:u})}
  async function logFlag(){const u=pruneOld([...flagLog,Date.now()],RATE.MS_24H);setFlagLog(u);await pSet("flag-log",{flags:u})}
  async function logVote(){const u=pruneOld([...voteLog,Date.now()],RATE.MS_24H);setVoteLog(u);await pSet("vote-log",{votes:u})}

  // ═══ BLOCK ═══
  async function blockHandle(h){if(blockedHandles.includes(h))return;const u=[...blockedHandles,h];setBlockedHandles(u);await pSet("blocked-handles",{handles:u});flash(`Blocked ${h}.`)}
  async function unblockHandle(h){const u=blockedHandles.filter(x=>x!==h);setBlockedHandles(u);await pSet("blocked-handles",{handles:u});flash(`Unblocked ${h}.`)}

  // ═══ POST ACTIONS ═══
  async function submitPost(e){
    e.preventDefault();if(!covenantAccepted){flash("Accept the Covenant first.","warning");return}
    const ck=canPost();if(!ck.ok){flash(ck.reason==="daily"?S.rateLimit.postLimit:S.rateLimit.postBurst,"warning");return}
    const handle=form.handle.trim()||"Anonymous";const now=new Date();const exp=new Date(now);exp.setDate(exp.getDate()+RATE.EXPIRY_DAYS);
    const post={id:gid(),type:form.type,freeSubtype:form.type==="free"?form.freeSubtype:undefined,category:form.category,title:form.title.trim(),body:form.body.trim(),contactInfo:form.contactInfo.trim(),zone:form.zone,timebank:form.type==="free"?0:(parseInt(form.timebank)||0),handle,deviceId:deviceId?.id||"unknown",created:now.toISOString().slice(0,10),expires:exp.toISOString().slice(0,10),tags:form.tags.split(",").map(t=>t.trim().toLowerCase()).filter(Boolean),flags:0,flaggedBy:[],status:"active",zip:userZip?.zip||""};
    await sSet(`posts:${post.id}`,post);setPosts(prev=>[post,...prev]);await logPost();
    if(handle!=="Anonymous")await pSet("user-handle",{handle,created:Date.now()});
    const mp=(await pGet("my-posts"))||{postIds:[]};mp.postIds.push(post.id);await pSet("my-posts",mp);
    setForm({type:"offer",freeSubtype:"items",category:"skills",title:"",body:"",contactInfo:"",zone:"Any / Network-wide",timebank:"",handle:handle!=="Anonymous"?handle:"",tags:""});
    flash(S.post.successMsg);setView("browse");
  }

  async function renewPost(id){const p=posts.find(x=>x.id===id);if(!p)return;const now=new Date();const exp=new Date(now);exp.setDate(exp.getDate()+RATE.EXPIRY_DAYS);const u={...p,created:now.toISOString().slice(0,10),expires:exp.toISOString().slice(0,10)};await sSet(`posts:${id}`,u);setPosts(prev=>prev.map(x=>x.id===id?u:x));flash(S.expiration.renewed)}
  async function deletePost(id){if(id.startsWith("s"))return;await sDel(`posts:${id}`);setPosts(prev=>prev.filter(x=>x.id!==id))}

  async function flagPost(id){
    if(reportedIds.has(id))return;if(!covenantAccepted){flash("Accept the Covenant to flag.","warning");return}if(!canFlag()){flash(S.rateLimit.flagLimit);return}
    setReportedIds(prev=>new Set([...prev,id]));await logFlag();
    const post=posts.find(p=>p.id===id);if(!post)return;
    const age=deviceId?Date.now()-deviceId.created:RATE.MS_24H*2;const w=age<RATE.MS_24H?0.5:1;
    const u={...post,flags:(post.flags||0)+w,flaggedBy:[...(post.flaggedBy||[]),{deviceId:deviceId?.id,deviceAge:age,weight:w}]};
    if(u.flags>=RATE.FLAG_THRESHOLD){
      u.status="removed";await sSet(`posts:${id}`,u);
      // Create appeal entry
      const appeal={id:gid(),postId:id,originalPost:{title:u.title,body:u.body,handle:u.handle,category:u.category,type:u.type},
        flags:u.flags,flaggedBy:u.flaggedBy,appealText:null,restoreVotes:0,upholdVotes:0,voterIds:[],
        created:new Date().toISOString(),status:"pending",creatorDeviceId:u.deviceId};
      await sSet(`flagged-posts:${appeal.id}`,appeal);
      setAppeals(prev=>[appeal,...prev]);
      const newScore=await adjustTrust(TRUST.REMOVAL_PENALTY,"post_removed");setTrustData_(await getTrustData());
    } else { await sSet(`posts:${id}`,u); }
    setPosts(prev=>prev.map(p=>p.id===id?u:p).filter(p=>p.status==="active"));
    flash("Post flagged.");
  }

  // ═══ APPEALS ═══
  async function submitAppeal(appealId,text){
    const a=appeals.find(x=>x.id===appealId);if(!a)return;
    const u={...a,appealText:text.slice(0,500)};
    await sSet(`flagged-posts:${appealId}`,u);
    setAppeals(prev=>prev.map(x=>x.id===appealId?u:x));
    flash(S.review.appealSuccess);
  }

  async function voteOnAppeal(appealId,vote){
    if(!covenantAccepted){flash("Accept the Covenant to vote.","warning");return}
    if(!canVote()){flash("You've voted enough today. Thank you.","warning");return}
    if(myVotedAppeals.has(appealId))return;
    const a=appeals.find(x=>x.id===appealId);if(!a||a.status!=="pending")return;
    await logVote();
    const u={...a};
    if(vote==="restore")u.restoreVotes=(u.restoreVotes||0)+1;
    else u.upholdVotes=(u.upholdVotes||0)+1;
    u.voterIds=[...(u.voterIds||[]),deviceId?.id];

    // Check thresholds
    if(u.restoreVotes>=RATE.APPEAL_RESTORE){
      u.status="restored";
      const orig=await sGet(`posts:${a.postId}`);
      if(orig){orig.status="active";orig.flags=0;orig.flaggedBy=[];await sSet(`posts:${a.postId}`,orig);setPosts(prev=>[orig,...prev])}
      const ns=await adjustTrust(TRUST.APPEAL_BONUS,"appeal_restored");setTrustData_(await getTrustData());
    } else if(u.upholdVotes>=RATE.APPEAL_UPHOLD){
      u.status="upheld";
      const ns=await adjustTrust(TRUST.REMOVAL_PENALTY,"appeal_upheld");setTrustData_(await getTrustData());
    }
    await sSet(`flagged-posts:${appealId}`,u);
    setAppeals(prev=>prev.map(x=>x.id===appealId?u:x).filter(x=>x.status==="pending"));
    const nv=new Set([...myVotedAppeals,appealId]);setMyVotedAppeals(nv);await pSet("my-voted-appeals",{ids:[...nv]});
    flash(S.review.votedMsg);
  }

  // ═══ TIME BANK ═══
  async function submitTb(e){e.preventDefault();if(!covenantAccepted){flash("Accept the Covenant first.","warning");return}
    const entry={id:gid(),from:tbForm.from.trim(),to:tbForm.to.trim(),hours:parseFloat(tbForm.hours)||0,description:tbForm.description.trim(),timestamp:new Date().toISOString().slice(0,10)};
    const u=[entry,...tbLog];setTbLog(u);await sSet("timebank-ledger",{entries:u});setTbForm({from:"",to:"",hours:"",description:""});flash(S.timebank.successMsg)}

  // ═══ COALITIONS ═══
  async function submitCoalition(e){e.preventDefault();if(!covenantAccepted){flash("Accept the Covenant first.","warning");return}
    const members=cForm.members.split(",").map(m=>m.trim()).filter(Boolean);if(members.length<2){flash("Need at least 2 members.","warning");return}
    const c={id:gid(),title:cForm.title.trim(),purpose:cForm.purpose.trim(),members,contact:cForm.contact.trim(),zone:cForm.zone,created:new Date().toISOString().slice(0,10)};
    await sSet(`coalitions:${c.id}`,c);setCoalitions(prev=>[c,...prev]);setCForm({title:"",purpose:"",members:"",contact:"",zone:"Any / Network-wide"});flash(S.coalitions.successMsg)}

  function revealContact(p){if(!covenantAccepted){flash("Accept the Covenant first.","warning");return}setContactModal({handle:p.handle,contactInfo:p.contactInfo})}
  function findMatches(p){if(p.type!=="need")return[];return posts.filter(x=>x.type==="offer"&&x.id!==p.id&&x.status==="active"&&(x.category===p.category||p.tags.some(t=>x.tags.includes(t)))).slice(0,2)}

  // ═══ FILTERING ═══
  const visible=posts.filter(p=>{
    if(p.status!=="active"||isExpired(p)||blockedHandles.includes(p.handle))return false;
    if(catFilter!=="all"&&p.category!==catFilter)return false;
    if(typeFilter!=="all"&&p.type!==typeFilter)return false;
    if(zoneFilter!=="all"&&p.zone!==zoneFilter&&p.zone!=="Any / Network-wide")return false;
    if(radiusFilter!=="any"&&userZip?.lat){const d=getPostDist(p);if(d!=null&&d>parseInt(radiusFilter))return false}
    if(search){const s=search.toLowerCase();return p.title.toLowerCase().includes(s)||p.body.toLowerCase().includes(s)||p.tags.some(t=>t.includes(s))}
    return true;
  });
  const totalHours=tbLog.reduce((s,e)=>s+e.hours,0);
  const active=posts.filter(p=>p.status==="active"&&!isExpired(p));
  const needCount=active.filter(p=>p.type==="need").length;
  const offerCount=active.filter(p=>p.type==="offer").length;
  const freeCount=active.filter(p=>p.type==="free").length;
  const postCheck=canPost();
  const pendingAppeals=appeals.filter(a=>a.status==="pending"&&appealDaysLeft(a)>0);

  if(!loaded)return (<div className="root" style={{display:"flex",alignItems:"center",justifyContent:"center",minHeight:"100vh"}}><div style={{textAlign:"center",color:"var(--moss)",fontFamily:"'Cormorant Garamond',serif",fontStyle:"italic",fontSize:"1.1rem"}}><div style={{marginBottom:"0.5rem",animation:"shimmer 2s ease-in-out infinite"}}>❧</div>Loading the commons…</div></div>);

  return (
    <div className="root">
      <a href="#main-content" className="skip-link">Skip to main content</a>
      {!covenantAccepted&&<CovenantWall onAccept={acceptCovenant}/>}
      {contactModal&&<div className="modal-overlay" role="dialog" onClick={()=>setContactModal(null)}><div className="modal" onClick={e=>e.stopPropagation()}><div className="modal-title">Contact — {contactModal.handle}</div><div className="contact-modal-safety">{S.contact.safetyMsg}</div><div className="contact-modal-info">{contactModal.contactInfo}</div><button className="modal-close" onClick={()=>setContactModal(null)}>Close</button></div></div>}
      {trustModal&&<div className="modal-overlay" role="dialog" onClick={()=>setTrustModal(false)}><div className="modal" onClick={e=>e.stopPropagation()}>
        <div className="modal-title">{S.trust.title}</div>
        <div className="trust-modal-score">{trustData.score.toFixed(1)}</div>
        <div className="modal-body">{S.trust.explainer}</div>
        <ul className="trust-modal-rules"><li>{S.trust.startVal}</li><li>{S.trust.exchange}</li><li>{S.trust.survives}</li><li>{S.trust.flagPenalty}</li><li>{S.trust.removal}</li><li>{S.trust.appealBonus}</li><li>{S.trust.floor}</li><li>{S.trust.ceiling}</li></ul>
        {trustData.history.length>0&&<div className="trust-history"><div style={{fontSize:".65rem",color:"var(--sage)",letterSpacing:".3em",textTransform:"uppercase",marginBottom:".5rem",fontFamily:"'Cormorant Garamond',serif"}}>History</div>
          {trustData.history.slice(-10).reverse().map((ev,i)=><div key={i} className="trust-event"><span>{ev.event.replace(/_/g," ")}</span><span className={`trust-event-delta ${ev.delta>0?"trust-delta-pos":"trust-delta-neg"}`}>{ev.delta>0?"+":""}{ev.delta}</span></div>)}
        </div>}
        <button className="modal-close" onClick={()=>setTrustModal(false)}>Close</button>
      </div></div>}

      <header className="header" role="banner"><div className="header-eyebrow">{S.header.eyebrow}</div><div className="vine-divider" aria-hidden="true">{S.header.vine}</div><h1 className="header-title"><span>Root</span> System</h1><div className="vine-divider" aria-hidden="true">❧ ✦ ❧ ✦ ❧</div><div className="header-subtitle">{S.header.subtitle}</div></header>

      <nav className="nav" role="navigation" aria-label="Main navigation">
        {[{id:"browse",label:S.nav.browse},{id:"post",label:S.nav.post},{id:"timebank",label:S.nav.timebank},{id:"coalitions",label:S.nav.coalitions},{id:"review",label:S.nav.review,count:pendingAppeals.length},{id:"safety",label:S.nav.safety,dot:true},{id:"about",label:S.nav.about}].map(({id,label,dot,count})=>(
          <button key={id} className={`nav-btn${view===id?" active":""}`} onClick={()=>setView(id)} aria-current={view===id?"page":undefined}>
            {label}{dot&&<span className="nav-dot" aria-label="Important"/>}{count>0&&<span className="nav-count">{count}</span>}
          </button>
        ))}
      </nav>

      <main className="main" id="main-content" ref={mainRef} tabIndex={-1}>
        {msg&&<div className={msgType==="error"?"error-msg":msgType==="warning"?"warning-msg":"success-msg"} role="status" aria-live="polite">{msg}</div>}

        {/* ═══ BROWSE ═══ */}
        {view==="browse"&&(<>
          <div className="section-label" role="heading" aria-level={2}>{S.browse.sectionLabel(offerCount,needCount,freeCount)}</div>
          <div className="zip-bar">{!userZip?(<><span className="zip-label">{S.zip.prompt}</span><form onSubmit={handleZipSubmit} style={{display:"flex",gap:".4rem",alignItems:"center"}}><input className="zip-input-sm" placeholder="zip" maxLength={5} value={zipInput} onChange={e=>setZipInput(e.target.value.replace(/\D/g,""))} aria-label="Zip code"/><button type="submit" className="chip" disabled={zipLooking} style={{minHeight:"44px"}}>{zipLooking?"…":"Set"}</button></form><span className="field-hint" style={{marginTop:0}}>{S.zip.hint}</span></>):(<><span className="zip-set">📍 {userZip.city?`${userZip.city}, ${userZip.state}`:`Zip ${userZip.zip}`}</span><button className="zip-change-btn" onClick={()=>{setUserZip(null);pSet("user-zip",null)}}>{S.zip.changeBtn}</button></>)}</div>
          <div className="filters" role="search" aria-label="Filter posts">
            <button className={`chip${typeFilter==="all"?" active":""}`} onClick={()=>setTypeFilter("all")} aria-pressed={typeFilter==="all"}>{S.browse.allFilter}</button>
            <button className={`chip type-offer${typeFilter==="offer"?" active":""}`} onClick={()=>setTypeFilter(typeFilter==="offer"?"all":"offer")} aria-pressed={typeFilter==="offer"}>{S.browse.offerFilter}</button>
            <button className={`chip type-need${typeFilter==="need"?" active":""}`} onClick={()=>setTypeFilter(typeFilter==="need"?"all":"need")} aria-pressed={typeFilter==="need"}>{S.browse.needFilter}</button>
            <button className={`chip type-free${typeFilter==="free"?" active":""}`} onClick={()=>setTypeFilter(typeFilter==="free"?"all":"free")} aria-pressed={typeFilter==="free"}>{S.browse.freeFilter}</button>
            <span style={{color:"rgba(196,152,46,.2)",margin:"0 .25rem"}} aria-hidden="true">✦</span>
            {CATEGORIES.map(cat=><button key={cat.id} className={`chip${catFilter===cat.id?" active":""}`} onClick={()=>setCatFilter(catFilter===cat.id?"all":cat.id)} aria-pressed={catFilter===cat.id}><span aria-hidden="true">{cat.emoji}</span> {cat.label}</button>)}
            <span style={{color:"rgba(196,152,46,.2)",margin:"0 .25rem"}} aria-hidden="true">✦</span>
            <select className="search-input" style={{width:"auto",paddingRight:".5rem"}} value={zoneFilter} onChange={e=>setZoneFilter(e.target.value)} aria-label="Zone">{[["all","All Zones"],...ZONES.map(z=>[z,z])].map(([v,l])=><option key={v} value={v}>{l}</option>)}</select>
            {userZip&&<select className="search-input" style={{width:"auto",paddingRight:".5rem"}} value={radiusFilter} onChange={e=>setRadiusFilter(e.target.value)} aria-label="Distance">{RADIUS_OPTIONS.map(r=><option key={r.value} value={r.value}>{r.label}</option>)}</select>}
            <input className="search-input" placeholder={S.browse.searchPlaceholder} value={search} onChange={e=>setSearch(e.target.value)} aria-label="Search"/>
            <button className="chip" onClick={()=>window.print()} style={{marginLeft:"auto"}}><span aria-hidden="true">🖨</span> {S.browse.printBtn}</button>
          </div>
          {visible.length===0?<div className="empty" role="status"><div className="empty-icon" aria-hidden="true">🌿</div>{S.browse.empty}</div>:(
            <div className="card-grid">{visible.map(post=>{
              const matches=findMatches(post);const flagged=(post.flags||0)>=2;const cat=CATEGORIES.find(c=>c.id===post.category);
              const isOwn=post.deviceId===deviceId?.id;const dist=getPostDist(post);const expL=expiryLabel(post);const dLeft=post.id.startsWith("s")?null:daysUntilExpiry(post.created);
              const showRenew=isOwn&&dLeft!=null&&dLeft<=RATE.RENEW_WARN&&dLeft>0;const warnings=detectScamWarnings(post);
              return (<article key={post.id} className={`card ${post.type}${flagged?" flagged":""}`}>
                <span className="card-corner" aria-hidden="true">{cat?.emoji||"✦"}</span>
                <div className={`card-type-badge badge-${post.type}`}>
                  <span>{post.type==="offer"?"◆ Offering":post.type==="need"?"◇ Seeking":""}</span>
                  {post.type==="free"&&<span className="free-badge"><span aria-hidden="true">🌿</span> Freely Given{post.freeSubtype?` · ${post.freeSubtype}`:""}</span>}
                  {(post.flags||0)>0&&<span style={{color:"#c07050",marginLeft:"auto",fontSize:".6rem"}}>⚑ {Math.ceil(post.flags)}</span>}
                </div>
                <h3 className="card-title">{post.title}</h3>
                {post.zone&&post.zone!=="Any / Network-wide"&&<div className="card-zone">◉ {post.zone}</div>}
                <div className="card-body">{post.body}</div>
                {/* Scam pattern warnings */}
                {warnings.filter(w=>!dismissedWarnings.has(post.id+w.id)).map(w=>(
                  <div key={w.id} className="scam-warning"><span>{w.msg}</span><button className="scam-warning-dismiss" onClick={()=>setDismissedWarnings(prev=>new Set([...prev,post.id+w.id]))} aria-label="Dismiss warning">✕</button></div>
                ))}
                {post.contactInfo&&<button className="contact-reveal-btn" onClick={()=>revealContact(post)}><span aria-hidden="true">📬</span> {S.contact.revealBtn}</button>}
                <div className="card-tags">{post.tags.map(t=><span key={t} className="tag">#{t}</span>)}</div>
                <div className="card-meta">
                  <span>{post.handle} · {fmt(post.created)}{" · "}<span className="trust-badge" onClick={()=>setTrustModal(true)}>trust: {trustData.score.toFixed(1)}</span>
                    {dist!=null&&<>{" · "}<span className="distance-badge">{distLabel(dist)}</span></>}
                    {expL&&<>{" · "}<span className={`expiry-badge${dLeft!=null&&dLeft<=2?" urgent":""}`}>{expL}</span></>}
                    {showRenew&&<>{" "}<button className="renew-btn" onClick={()=>renewPost(post.id)}>{S.expiration.renewBtn}</button></>}
                  </span>
                  <div className="card-actions">
                    {post.timebank>0&&<span className="tb-badge"><span aria-hidden="true">⏱</span> {post.timebank}h</span>}
                    {isOwn&&!post.id.startsWith("s")&&<button className="action-btn delete-action" onClick={()=>deletePost(post.id)} title="Remove">✕</button>}
                    {!isOwn&&<button className="action-btn block-action" onClick={()=>blockHandle(post.handle)} title="Block">⊘</button>}
                    <button className={`action-btn${reportedIds.has(post.id)?" flagged-state":""}`} onClick={()=>flagPost(post.id)} title="Flag">⚑ {reportedIds.has(post.id)?"flagged":"flag"}</button>
                  </div>
                </div>
                {matches.length>0&&<div className="match-banner"><span aria-hidden="true">✦</span> Matching: {matches.map(m=>m.title).join(" · ")}</div>}
              </article>)})}</div>
          )}
          {blockedHandles.length>0&&<div style={{marginTop:"2rem"}}><button className="chip" onClick={()=>setShowBlocked(!showBlocked)} aria-expanded={showBlocked}>{showBlocked?"Hide":"Show"} blocked ({blockedHandles.length})</button>{showBlocked&&<div className="blocked-list">{blockedHandles.map(h=><div key={h} className="blocked-item"><span>{h}</span><button className="unblock-btn" onClick={()=>unblockHandle(h)}>{S.block.unblockBtn}</button></div>)}</div>}</div>}
        </>)}

        {/* ═══ POST FORM ═══ */}
        {view==="post"&&(<div className="form-wrap"><h2 className="form-title">{S.post.title}</h2><p className="form-desc">{S.post.desc}</p>
          <div className="privacy-warning">{S.post.privacyWarning}</div>
          <div className="compact-box"><div className="compact-title"><span aria-hidden="true">✦</span> {S.post.compactTitle}</div><ul className="compact-rules">{COMPACT_RULES.map((r,i)=><li key={i}>{r}</li>)}</ul></div>
          {!covenantAccepted&&<div className="warning-msg">Accept the Community Covenant before posting.</div>}
          <form onSubmit={submitPost}>
            <label className="field-label">I am…</label>
            <div className="type-toggle"><button type="button" className={`type-btn offer${form.type==="offer"?" active":""}`} onClick={()=>setForm(f=>({...f,type:"offer"}))}>{S.post.offering}</button><button type="button" className={`type-btn need${form.type==="need"?" active":""}`} onClick={()=>setForm(f=>({...f,type:"need"}))}>{S.post.seeking}</button><button type="button" className={`type-btn free-type${form.type==="free"?" active":""}`} onClick={()=>setForm(f=>({...f,type:"free"}))}>{S.post.freeGiving}</button></div>
            {form.type==="free"&&<><label className="field-label">{S.post.freeSubLabel}</label><div className="free-sub-toggle">{FREE_SUBTYPES.map(st=><button key={st.id} type="button" className={`free-sub-btn${form.freeSubtype===st.id?" active":""}`} onClick={()=>setForm(f=>({...f,freeSubtype:st.id}))}>{st.label}</button>)}</div></>}
            <label className="field-label" htmlFor="pc">{S.post.catLabel}</label><select id="pc" className="form-select" value={form.category} onChange={e=>setForm(f=>({...f,category:e.target.value}))}>{CATEGORIES.map(c=><option key={c.id} value={c.id}>{c.emoji} {c.label}</option>)}</select>
            <label className="field-label" htmlFor="pz">{S.post.zoneLabel}</label><select id="pz" className="form-select" value={form.zone} onChange={e=>setForm(f=>({...f,zone:e.target.value}))}>{ZONES.map(z=><option key={z} value={z}>{z}</option>)}</select><div className="field-hint">{S.post.zoneHint}</div>
            <label className="field-label" htmlFor="pt">{S.post.titleLabel}</label><input id="pt" className="form-input" required placeholder={S.post.titlePH} value={form.title} onChange={e=>setForm(f=>({...f,title:e.target.value}))}/>
            <label className="field-label" htmlFor="pb">{S.post.bodyLabel}</label><textarea id="pb" className="form-textarea" required placeholder={S.post.bodyPH} value={form.body} onChange={e=>setForm(f=>({...f,body:e.target.value}))}/>
            <label className="field-label" htmlFor="pci">{S.post.contactLabel}</label><input id="pci" className="form-input" placeholder={S.post.contactPH} value={form.contactInfo} onChange={e=>setForm(f=>({...f,contactInfo:e.target.value}))}/><div className="field-hint">{S.post.contactHint}</div>
            <label className="field-label" htmlFor="ph">{S.post.handleLabel}</label><input id="ph" className="form-input" placeholder={S.post.handlePH} value={form.handle} onChange={e=>setForm(f=>({...f,handle:e.target.value}))}/>
            {form.type!=="free"&&<><label className="field-label" htmlFor="ptb">{S.post.tbLabel}</label><input id="ptb" className="form-input" type="number" min="0" value={form.timebank} onChange={e=>setForm(f=>({...f,timebank:e.target.value}))}/></>}
            <label className="field-label" htmlFor="ptg">{S.post.tagsLabel}</label><input id="ptg" className="form-input" placeholder={S.post.tagsPH} value={form.tags} onChange={e=>setForm(f=>({...f,tags:e.target.value}))}/>
            <button type="submit" className="submit-btn" disabled={!covenantAccepted}>{S.post.submitBtn} →</button>
            {postCheck.ok&&<div className="rate-limit-footer">{S.rateLimit.remaining(postCheck.remaining)}</div>}
          </form>
        </div>)}

        {/* ═══ TIME BANK ═══ */}
        {view==="timebank"&&(<><div className="section-label" role="heading" aria-level={2}>{S.timebank.sectionLabel}</div>
          <p style={{fontSize:".88rem",color:"#907a50",lineHeight:1.75,maxWidth:"560px",marginBottom:"2rem"}}>{S.timebank.desc}</p>
          <div className="tb-grid"><div>
            <div className="tb-stat"><span className="tb-stat-num">{totalHours.toFixed(1)}</span><span className="tb-stat-label">{S.timebank.totalHours}</span></div>
            <div className="tb-stat"><span className="tb-stat-num">{tbLog.length}</span><span className="tb-stat-label">{S.timebank.totalExchanges}</span></div>
            <div style={{marginTop:"1.5rem"}}><div className="section-label">{S.timebank.logLabel}</div>
              {!covenantAccepted&&<div className="warning-msg">Accept the Covenant to log exchanges.</div>}
              <form onSubmit={submitTb}><label className="field-label" htmlFor="tf">Who gave?</label><input id="tf" className="form-input" required placeholder="Name/handle" value={tbForm.from} onChange={e=>setTbForm(f=>({...f,from:e.target.value}))}/><label className="field-label" htmlFor="tt">Who received?</label><input id="tt" className="form-input" required placeholder="Name/handle" value={tbForm.to} onChange={e=>setTbForm(f=>({...f,to:e.target.value}))}/><label className="field-label" htmlFor="th">Hours</label><input id="th" className="form-input" required type="number" min="0.25" step="0.25" placeholder="1.0" value={tbForm.hours} onChange={e=>setTbForm(f=>({...f,hours:e.target.value}))}/><label className="field-label" htmlFor="tw">What?</label><input id="tw" className="form-input" required placeholder="e.g. 3hrs childcare" value={tbForm.description} onChange={e=>setTbForm(f=>({...f,description:e.target.value}))}/><button type="submit" className="submit-btn" disabled={!covenantAccepted}>{S.timebank.submitBtn} →</button></form>
            </div>
          </div><div><div className="section-label">{S.timebank.ledgerLabel}</div>{tbLog.length===0?<div className="empty" style={{padding:"2rem 0",textAlign:"left"}}>{S.timebank.emptyLedger}</div>:tbLog.map(e=><div key={e.id} className="tb-entry"><div className="tb-entry-main">{e.hours}h — {e.description}</div><div className="tb-entry-sub">{e.from} → {e.to} · {fmt(e.timestamp)}</div></div>)}</div></div>
        </>)}

        {/* ═══ COALITIONS ═══ */}
        {view==="coalitions"&&(<><div className="section-label" role="heading" aria-level={2}>{S.coalitions.sectionLabel}</div>
          <p style={{fontSize:".88rem",color:"#907a50",lineHeight:1.75,maxWidth:"560px",marginBottom:"2rem"}}>{S.coalitions.desc}</p>
          {coalitions.filter(c=>c.members.length>=2).map(c=><div key={c.id} className="coalition-card"><h3 className="coalition-title">{c.title}</h3><div className="coalition-meta">{c.zone} · Started {fmt(c.created)} · {c.contact}</div><div className="coalition-body">{c.purpose}</div><div className="coalition-members">{c.members.map(m=><span key={m} className="member-chip">{m}</span>)}</div></div>)}
          <div style={{marginTop:"2.5rem",borderTop:"1px solid rgba(196,152,46,.1)",paddingTop:"2rem"}}><div className="section-label">{S.coalitions.startLabel}</div>
            {!covenantAccepted&&<div className="warning-msg">Accept the Covenant first.</div>}
            <div className="form-wrap"><form onSubmit={submitCoalition}>
              <label className="field-label" htmlFor="cn">Name</label><input id="cn" className="form-input" required placeholder="e.g. Eastside Tool Library" value={cForm.title} onChange={e=>setCForm(f=>({...f,title:e.target.value}))}/>
              <label className="field-label" htmlFor="cp">Purpose</label><textarea id="cp" className="form-textarea" required placeholder="What is this coalition doing?" value={cForm.purpose} onChange={e=>setCForm(f=>({...f,purpose:e.target.value}))}/>
              <label className="field-label" htmlFor="cz">Zone</label><select id="cz" className="form-select" value={cForm.zone} onChange={e=>setCForm(f=>({...f,zone:e.target.value}))}>{ZONES.map(z=><option key={z} value={z}>{z}</option>)}</select>
              <label className="field-label" htmlFor="cm">Members (comma separated)</label><input id="cm" className="form-input" placeholder="Ana K., Marcus W." value={cForm.members} onChange={e=>setCForm(f=>({...f,members:e.target.value}))}/><div className="field-hint">Min 2 members to be visible.</div>
              <label className="field-label" htmlFor="cc">Contact</label><input id="cc" className="form-input" required placeholder="Email, Signal, or meeting time" value={cForm.contact} onChange={e=>setCForm(f=>({...f,contact:e.target.value}))}/>
              <button type="submit" className="submit-btn" disabled={!covenantAccepted}>{S.coalitions.submitBtn} →</button>
            </form></div>
          </div>
        </>)}

        {/* ═══ COMMUNITY REVIEW ═══ */}
        {view==="review"&&(<><div className="section-label" role="heading" aria-level={2}>{S.review.sectionLabel}</div>
          <p style={{fontSize:".88rem",color:"#907a50",lineHeight:1.75,maxWidth:"640px",marginBottom:"2rem"}}>{S.review.desc}</p>
          {pendingAppeals.length===0?<div className="empty"><div className="empty-icon" aria-hidden="true">🌿</div>{S.review.empty}</div>:
            pendingAppeals.map(a=>{const dLeft=appealDaysLeft(a);const voted=myVotedAppeals.has(a.id);const isCreator=a.creatorDeviceId===deviceId?.id;
              return (<div key={a.id} className="appeal-card">
                <div className="appeal-header">Flagged post by {a.originalPost.handle}</div>
                <div className="appeal-original"><strong>{a.originalPost.title}</strong><br/>{a.originalPost.body}</div>
                {a.appealText?<div className="appeal-text">Appeal: "{a.appealText}"</div>:
                  isCreator?<div style={{marginTop:".5rem"}}><textarea className="form-textarea" style={{minHeight:"60px"}} maxLength={500} placeholder={S.review.appealPH} value={appealText} onChange={e=>setAppealText(e.target.value)}/><button className="chip" style={{marginTop:".3rem"}} onClick={()=>{submitAppeal(a.id,appealText);setAppealText("")}}>{S.review.appealSubmit}</button></div>:
                  <div className="appeal-text" style={{color:"#504838"}}>No appeal submitted yet.</div>
                }
                <div className="appeal-meta">Flags: {Math.ceil(a.flags)} · {dLeft}d remaining · <span className="vote-counts">Restore: {a.restoreVotes||0} · Uphold: {a.upholdVotes||0}</span></div>
                {!isCreator&&<div className="appeal-votes">
                  <button className="vote-btn restore" disabled={voted||!covenantAccepted} onClick={()=>voteOnAppeal(a.id,"restore")}>↻ {S.review.restoreBtn}</button>
                  <button className="vote-btn uphold" disabled={voted||!covenantAccepted} onClick={()=>voteOnAppeal(a.id,"uphold")}>✕ {S.review.upholdBtn}</button>
                  {voted&&<span style={{fontSize:".7rem",color:"var(--sage)",fontStyle:"italic",display:"flex",alignItems:"center"}}>You voted</span>}
                </div>}
              </div>)})
          }
        </>)}

        {/* ═══ SAFETY ═══ */}
        {view==="safety"&&(<><div className="section-label" role="heading" aria-level={2}>Safe Exchange Protocol</div>
          <p style={{fontSize:".88rem",color:"#907a50",lineHeight:1.75,maxWidth:"640px",marginBottom:"2rem"}}>This network exists to serve your dignity and safety.</p>
          <div className="safety-grid">
            <div className="safety-card"><span className="safety-icon" aria-hidden="true">🌿</span><h3 className="safety-title">First Meetings</h3><ul className="safety-body"><li>Meet in public first</li><li>Tell someone where you're going</li><li>Bring a friend</li><li>Drive separately</li><li>Trust your gut</li></ul></div>
            <div className="safety-card"><span className="safety-icon" aria-hidden="true">🔒</span><h3 className="safety-title">Privacy</h3><ul className="safety-body"><li>Use Signal for communication</li><li>ProtonMail for email</li><li>Never required to give your real name</li><li>Never post an address</li><li>Anonymous posting is valid</li></ul></div>
            <div className="safety-card"><span className="safety-icon" aria-hidden="true">⚖️</span><h3 className="safety-title">Fair Exchange</h3><ul className="safety-body"><li>One hour = one hour</li><li>Clear agreements first</li><li>You can stop at any point</li><li>Mutual aid is gift economy</li><li>Pressure = red flag</li></ul></div>
            <div className="safety-card safety-critical"><span className="safety-icon" aria-hidden="true">⚑</span><h3 className="safety-title">Flagging & Appeals</h3><ul className="safety-body"><li>Flag anything that concerns you</li><li>3 flags → post hidden, appeal available</li><li>Community votes to restore or uphold</li><li>No penalty for good-faith flagging</li><li>Check the Review tab for pending appeals</li></ul></div>
            <div className="safety-card"><span className="safety-icon" aria-hidden="true">🤲</span><h3 className="safety-title">Boundaries & Grooming</h3><ul className="safety-body"><li>No sexual services or implied exchanges</li><li>Trust takes time — excessive generosity deserves scrutiny</li><li>Watch for: love bombing, manufactured urgency, isolation, boundary testing</li><li>If unsafe, stop — no explanation needed</li><li>Warn the community about bad actors</li></ul></div>
            <div className="safety-card"><span className="safety-icon" aria-hidden="true">📞</span><h3 className="safety-title">Resources</h3><ul className="resource-list"><li><strong>988:</strong> Suicide & Crisis Lifeline</li><li><strong>741741:</strong> Crisis Text Line</li><li><strong>1-800-656-4673:</strong> RAINN</li><li><strong>1-800-799-7233:</strong> DV Hotline</li><li><strong>1-800-662-4357:</strong> SAMHSA</li><li><strong>211:</strong> Local services</li><li><strong>signal.org</strong> · <strong>proton.me</strong></li><li><strong>findhelp.org</strong> · <strong>benefitscheckup.org</strong></li></ul></div>
          </div>
          <div className="red-flag-box"><div className="red-flag-title"><span aria-hidden="true">⚑</span> Red Flags</div><ul className="red-flag-list"><li>Money upfront</li><li>Urgency pressure</li><li>Won't meet in public</li><li>Vague about their offer</li><li>Asks for documents or ID</li><li>Too-good offers</li><li>Creates false debt</li><li>Dismisses your concerns</li></ul></div>
        </>)}

        {/* ═══ ABOUT ═══ */}
        {view==="about"&&(<><div className="section-label" role="heading" aria-level={2}>The Community Compact</div>
          <div className="manifesto-drop">"Helping your neighbor is not an ideology. It is older than any movement that has tried to claim it."</div>
          <h3 className="about-h">What is Root System?</h3><p className="about-p">A free tool for neighbors helping neighbors. No accounts, no ads, no cost.</p>
          <h3 className="about-h">Who is it for?</h3><p className="about-p">Anyone. Churches, rural counties, neighborhoods. Designed for adults. Under 18? Call 211.</p>
          <h3 className="about-h">Time banking</h3><p className="about-p">One hour equals one hour, regardless of skill.</p>
          <h3 className="about-h">Coalitions</h3><p className="about-p">Group projects — tool libraries, buying clubs, childcare co-ops. Min 2 members.</p>
          <h3 className="about-h">Privacy</h3><p className="about-p">No tracking, no advertising. Posts are public and expire after 7 days.</p>
          <h3 className="about-h">Safety</h3><p className="about-p">Covenant, flagging, appeals, trust scores, and the Safety section. Flag what concerns you. Block who you need to.</p>
          <h3 className="about-h">This is yours.</h3><p className="about-p">Fork it. Run it for your community. Keep the good faith intact.</p>
        </>)}
      </main>

      <footer className="footer" role="contentinfo"><span>{S.footer.name}</span><span>{S.footer.license}</span><span>{S.footer.use}</span><div className="footer-crisis">{S.footer.crisis}</div></footer>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════════════════
// COVENANT WALL
// ═══════════════════════════════════════════════════════════════════════════════
function CovenantWall({onAccept}){
  const [c1,setC1]=useState(false);const [c2,setC2]=useState(false);const [scrolled,setScrolled]=useState(false);
  const [curQ,setCurQ]=useState(0);const [answers,setAnswers]=useState({});const [wrong,setWrong]=useState(null);const [allOk,setAllOk]=useState(false);
  const ref=useRef(null);const show=c1&&c2&&scrolled;
  function onScroll(){const el=ref.current;if(el&&el.scrollHeight-el.scrollTop-el.clientHeight<30)setScrolled(true)}
  function pick(qId,key){const q=COMP_QUESTIONS.find(x=>x.id===qId);if(!q||answers[qId])return;
    if(key===q.correct){const na={...answers,[qId]:key};setAnswers(na);setWrong(null);if(Object.keys(na).length===COMP_QUESTIONS.length)setAllOk(true);else setTimeout(()=>setCurQ(c=>c+1),600)}
    else setWrong({qId,key})}
  const q=COMP_QUESTIONS[curQ];
  return (<div className="covenant-overlay" role="dialog" aria-label="Community Covenant"><div className="covenant-card">
    <div className="covenant-header">The <span>Root System</span> Covenant</div><div className="covenant-vine" aria-hidden="true">❧ ✦ ❧ ✦ ❧</div>
    <div className="covenant-minor-notice">{S.covenant.minorNotice}</div>
    <div className="covenant-body" ref={ref} onScroll={onScroll} tabIndex={0} aria-label="Covenant text">
      {COVENANT_TEXT.map((s,i)=><div key={i} className="covenant-section">{s.h&&<div className="covenant-section-heading">{s.h}</div>}<div className="covenant-section-body">{s.b}</div></div>)}
    </div>
    {!scrolled&&<div className="covenant-scroll-indicator" aria-hidden="true">↓ scroll to read ↓</div>}
    <div className="covenant-checkbox-area">
      <label className="covenant-check-row"><input type="checkbox" checked={c1} onChange={e=>setC1(e.target.checked)}/><span className="covenant-check-label">{S.covenant.checkbox1}</span></label>
      <label className="covenant-check-row"><input type="checkbox" checked={c2} onChange={e=>setC2(e.target.checked)}/><span className="covenant-check-label">{S.covenant.checkbox2}</span></label>
    </div>
    {show&&!allOk&&q&&<div className="comp-gate"><div className="comp-label">Comprehension Check</div><div className="comp-progress">{curQ+1} of {COMP_QUESTIONS.length}</div>
      <div className="comp-question">{q.question}</div>
      {q.options.map(o=>{const isC=answers[q.id]===o.key;const isW=wrong?.qId===q.id&&wrong?.key===o.key;
        return <button key={o.key} className={`comp-option${isC?" correct":""}${isW?" wrong":""}`} onClick={()=>pick(q.id,o.key)} disabled={!!answers[q.id]}>({o.key}) {o.text}</button>})}
      {wrong?.qId===q.id&&<div className="comp-hint"><strong>{S.covenant.wrongAnswer}</strong><br/><em>"{q.ref}"</em></div>}
    </div>}
    {allOk&&<button className="enter-btn" onClick={onAccept}>{S.covenant.enterBtn} →</button>}
  </div></div>);
}
